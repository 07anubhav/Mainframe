CONTROL STRUCTURE:
==================

- It is of 2 types Conditional and Iterative Statement
- DO ... END; or BEGIN ... END; is used when more than 1 statement is coded in IF Block or ELSE Block or SELECT Block respectively.

- Conditional Statement:
 - IF
 DEMO03: PROCEDURE OPTIONS(MAIN);
DCL CUST_NAME CHAR(10) INIT('ANUBHAV');
DCL CUST_ID FIXED DECIMAL(4) INIT(1001);
DCL BALANCE FLOAT DECIMAL(6) INIT(1000.38);
DCL EMAIL PIC '(20)X' INIT('AKS@GMAIL.COM');
DCL ACCOUNT_TYP CHAR(2);
DCL INPUT PIC '(3)A' INIT('END');

IF BALANCE > 500 & CUST_NAME = 'ANUBHAV' THEN
DO;
PUT SKIP LIST('ANUBHAV HAS ENOUGH BALANCE');
END;
ELSE
BEGIN; 
PUT SKIP LIST('ANUBHAV HAS NOT ENOUGH BALANCE');
END;
 - SELECT
GET (ACCOUNT_TYP);
SELECT(ACCOUNT_TYP)
WHEN('SB')
PUT SKIP LIST('SAVING ACCOUNT')
WHEN('RD')
PUT SKIP LIST('RECURRING ACCOUNT')
WHEN('CB')
PUT SKIP LIST('CURRENT ACCOUNT')
OTHERWISE
PUT SKIP LIST('INVALID ACCOUNT TYPE')
END;

- Iterative Statement
 - DO
DO I=1 TO 5 BY 1 | DO I=5 TO 1 BY -1
BEGIN;
PUT SKIP LIST('I: ' || I); //1 2 3 4 5
END;
END;

 - DO WHILE
DO WHILE(INPUT!='END')
BEGIN;
PUT SKIP LIST('INPUT IS:',INPUT);
END;
END;

 - DO UNTIL
- First block of statement is executed then logical expression is checked
- The statement will be executed atleast once
- These logical statements are executed until the expression is false
DO UNTIL(INPUT='END')
BEGIN;
PUT SKIP LIST('INPUT IS: ' || INPUT);
END;
END; 

 - DO LOOP
- Used to run infinite number of times
DO LOOP
INPUT = INPUT+1;
IF INPUT=50 THEN
LEAVE;
PUT SKIP LIST('INPUT IS: '||INPUT);
END;
 END DEMO03;
