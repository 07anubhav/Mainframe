 DEMO16: PROC OPTIONS(MAIN);

   DEFINE ORDINAL COLOR(RED,ORANGE,YELLOW,GREEN,BLUE,INDIGO);
   DCL CLR ORDINAL(COLOR);
   DO CLR=RED UPTHRU INDIGO;
      PUT SKIP LIST (ORDINALNAME(CLR));
      PUT SKIP LIST (BINARYVALUE(CLR));
   END;

   DCL TEST_COLOR TYPE COLOR;
   TEST_COLOR=BLUE;
   SELECT (TEST_COLOR)
     WHEN(BLUE) PUT LIST('SELECTED BLUE COLOR');
     WHEN(GREEN) PUT LIST('SELECTED GREEN COLOR');
     WHEN(ORANGE) PUT LIST('SELECTED ORANGE COLOR');
     WHEN(YELLOW) PUT LIST('SELECTED YELLOW COLOR');
   END;

   DCL NEXT_COLOR ORDINAL COLOR;
   DO NEXT_COLOR=FIRST(:COLOR:)
     REPEAT ORDINALSUCC(NEXT_COLOR)
     UNTIL (NEXT_COLOR=LAST(:COLOR:));
     PUT SKIP LIST(ORDINALNAME(NEXT_COLOR));
   END;

   END ORDINAL;


