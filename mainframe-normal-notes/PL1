 /*********************************************************************/
 /*CALLING EXTERNAL PROCEDURE                                         */
 /*********************************************************************/
  CALL EXTPROC;

 /*********************************************************************/
 /*DISPLAYING ALL VARIABLES TO UNDERSTAND THE SCOPE                   */
 /*********************************************************************/
  PUT SKIP LIST('INSIDE MAIN PROC AFTER INVOKING INT & EXT PROC')
  PUT SKIP LIST('MAIN PROC VAR1:'||MVAR1);
  PUT SKIP LIST('MAIN PROC VAR2:'||MVAR2);
  PUT SKIP LIST('STATIC    VAR1:'||SVAR1);
